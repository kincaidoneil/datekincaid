---
import ActionBanner from '@/components/ActionBanner.tsx'
import Layout from '@/layouts/Layout.astro'
import Hero from '@/assets/lisbon.jpg'
import RunningNight from '@/assets/running-night.jpg'
import RunningDay from '@/assets/running-day.jpg'
import Melon from '@/assets/melon.jpg'
import Chow from '@/assets/chow.jpg'
import Cat from '@/assets/cat.png'
import Fam from '@/assets/fam.jpg'
import {
  Cake,
  Ruler,
  MapPin,
  House,
  Baby,
  Landmark,
  School,
  Briefcase,
} from 'lucide-react'
import Chip from '@/components/Chip.astro'
import { Content as ValuesCopy } from '@/copy/values.md'
import { Content as LookingForCopy } from '@/copy/looking-for.md'
import { Content as WhyCopy } from '@/copy/why.md'
import { Content as IntroCopy } from '@/copy/intro.md'
import Prose from '@/components/Prose.astro'
import LightboxImage from '@/components/LightboxImage.astro'
import { Content as GathersCopy } from '@/copy/gathers.md'

// Hero height based on constrained width and aspect ratio
// max-w-xl => 36rem
// px-5 => 1.25rem * 2 = 2.5rem
const heroAspectRatio = (Hero.width / Hero.height).toFixed(5)
const heroHeight = `calc((min(100vw, 36rem) - 2.5rem) / ${heroAspectRatio})`

const STICKY_END_PERCENT = 0.413
const SPACER_PERCENT = 1 - STICKY_END_PERCENT

export const prerender = true
---

<Layout>
  <main class="relative mx-auto max-w-xl pb-12 font-serif @2xs:pt-20">
    {
      /*
        Scroll effect:
        Hero image is "sticky" as content scrolls over it, up to my eyes, then starts scrolling away.

        Hero image is wrapped in a sticky <div> *shorter* than itself. So, after this scroll distance,
        the hero image starts scrolling away.

        Then, add a spacer <div> so the wrapper is the true height of the hero image.
      */
    }
    <div class="relative box-content pt-8">
      <div
        class="sticky top-8 z-0 px-5"
        style={{
          height: `calc(${heroHeight} * ${STICKY_END_PERCENT})`,
        }}>
        <LightboxImage
          src={Hero}
          alt="Majestic man staring into the distance in Lisbon"
          priority={true}
        />
      </div>

      <div style={{ height: `calc(${heroHeight} * ${SPACER_PERCENT})` }}></div>

      {
        /*
          Inverted corners overlaid on hero image to maintain rounded corners, even while sticky.
          Refer to this SVG arc reference:
          https://developer.mozilla.org/en-US/docs/Web/SVG/Tutorials/SVG_from_scratch/Paths#arcs

          Negative margins are to prevent a glitch in Safari iOS where a slive of the underlying image
          is visible while scrolling because it doesn't properly overlap.
        */
      }
      <svg
        class="absolute bottom-0 left-5 -mb-[0.2px] -ml-[0.2px] h-6 w-6"
        viewBox="0 0 24 24">
        <path d="M 0 0 A 24 24, 0, 0, 0, 24 24 L 0 24 Z" class="fill-slate-50"
        ></path>
      </svg>

      <svg
        class="absolute right-5 bottom-0 -mr-[0.2px] -mb-[0.2px] h-6 w-6"
        viewBox="0 0 24 24">
        <path d="M 24 0 A 24 24, 0, 0, 1, 0 24 L 24 24 Z" class="fill-slate-50"
        ></path>
      </svg>
    </div>

    <Prose as="article" class="relative z-10 bg-slate-50 pt-4">
      <div class="pt-8">
        <section class="flex flex-col gap-16 px-5">
          <section class="flex flex-col gap-8">
            <header>
              <IntroCopy />
            </header>

            <div class="grid grid-cols-2 gap-x-1 gap-y-1">
              <Chip Icon={Cake} alt="Age"> 27 </Chip>
              <Chip Icon={Ruler} alt="Height"> 5’ 8.75” </Chip>
              <Chip Icon={MapPin} alt="Location"> Brooklyn, NY </Chip>
              <Chip Icon={House} alt="Hometown"> Minneapolis, MN </Chip>
              <Chip Icon={Baby} alt="Wants children"> In 5+ years </Chip>
              <Chip Icon={Landmark} alt="Politics"> Liberal </Chip>
              <Chip Icon={School} alt="Education">
                Northeastern University
              </Chip>
              <Chip Icon={Briefcase} alt="Work">
                <span>
                  Founder at <a
                    href="https://gathers.social?utm_source=date_kincaid"
                    target="_blank"
                    rel="noopener">
                    Gathers
                  </a>
                </span>
              </Chip>
            </div>
          </section>

          <section class="flex flex-col gap-8">
            <LightboxImage src={RunningDay} alt="Kincaid in motion" />

            <LightboxImage
              src={RunningNight}
              alt="Man (shredded), running in the night (run club in Boston)"
            />
          </section>

          <section>
            <ValuesCopy />
          </section>

          <section>
            <h3>Relationships</h3>

            <div class="not-prose flex w-full flex-row gap-4">
              <figure class="w-1/2">
                <LightboxImage
                  src={Fam}
                  alt="Kincaid smiling with his sister and dad"
                />
                <figcaption class="px-2 py-1 text-sm">The fam 🙂</figcaption>
              </figure>
              <figure class="m-0 w-1/2">
                <LightboxImage src={Chow} alt="Kincaid supporting a friend" />
              </figure>
            </div>

            <LightboxImage src={Melon} alt="Kincaid raising a melon" />
          </section>

          <section>
            <LookingForCopy />
          </section>

          <div class="flex flex-col gap-4 pb-8">
            <LightboxImage src={Cat} alt="Kincaid in the wild" />

            <h1 class="mt-0!">Now, you must choose.</h1>
          </div>
        </section>

        <ActionBanner client:visible>
          <Prose>
            <GathersCopy />
          </Prose>
        </ActionBanner>
      </div>

      <section class="px-5 pt-64">
        <WhyCopy />
      </section>
    </Prose>
  </main>
</Layout>
